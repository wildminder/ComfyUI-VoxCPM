# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/autoshop

# Auth
JWT_SECRET=generate-a-random-32-char-string-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Retell (for auto-provisioning)
RETELL_API_KEY=your-retell-api-key

# Twilio (for auto-provisioning phone numbers)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# n8n (for triggering config sync)
N8N_BASE_URL=https://your-n8n.example.com

# Optional: Cal.com
CALCOM_API_KEY=your-calcom-api-key
CALCOM_EVENT_TYPE_ID=12345
