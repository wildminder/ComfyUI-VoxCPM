# ============================================================
# AutoShop Voice Front Desk — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.

# --- n8n ---
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_ENCRYPTION_KEY=your-n8n-encryption-key

# --- Postgres / Supabase ---
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# --- Retell ---
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SMS_FROM=+15551112222

# --- Shop Alert (fallback for urgent notifications) ---
SHOP_ALERT_PHONE=+15559876543
SHOP_ALERT_EMAIL=owner@mikesautorepair.com

# --- Optional: Cal.com (for live booking) ---
CALCOM_API_KEY=your-calcom-api-key
CALCOM_EVENT_TYPE_ID=your-event-type-id

# --- Optional: Slack ---
SLACK_WEBHOOK_URL=your-slack-webhook-url

# --- Optional: DMS / Shop Management Integration ---
# Per-shop DMS credentials are stored in the dms_integrations table.
# This secret is used to verify inbound DMS webhooks.
DMS_WEBHOOK_SECRET=your-dms-webhook-secret

# --- Optional: Supabase (if using Supabase auth/storage) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
